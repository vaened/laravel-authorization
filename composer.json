{
  "name": "vaened/laravel-authorization",
  "description": "Package to manage the permissions in a laravel application",
  "type": "package",
  "license": "MIT",
  "authors": [
    {
      "name": "enea dhack",
      "email": "contact@vaened.dev"
    }
  ],
  "keywords": [
    "vaened",
    "laravel",
    "permission",
    "authorization",
    "acl",
    "security"
  ],
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "psr/log": "^3.0",
    "vaened/support": "^4.2"
  },
  "require-dev": {
    "orchestra/testbench": "^10.5",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Vaened\\Sentinel\\": "core",
      "Vaened\\Authorization\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vaened\\Authorization\\Tests\\": "tests"
    }
  }
}
