{
  "name": "vaened/laravel-authorization",
  "description": "Package to manage the permissions in a laravel application",
  "type": "package",
  "license": "MIT",
  "authors": [
    {
      "name": "enea dhack",
      "email": "contact@vaened.dev"
    }
  ],
  "keywords": [
    "vaened",
    "laravel",
    "permission",
    "authorization",
    "acl",
    "security"
  ],
  "repositories": [
    {
      "type": "path",
      "url": "../php-sentinel",
      "options": {
        "symlink": true
      }
    }
  ],
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "psr/log": "^3.0",
    "vaened/php-sentinel": "dev-master"
  },
  "require-dev": {
    "orchestra/testbench": "^10.5",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Vaened\\Authorization\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vaened\\Authorization\\Tests\\": "tests"
    }
  }
}
